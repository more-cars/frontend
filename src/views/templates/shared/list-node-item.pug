li(class="mb-4 bg-white border border-zinc-200 rounded-xl" data-testid=`${nodeType}-${nodeData.id}`)
    div(class="grid grid-flow-col grid-cols-8 gap-4")
        - thumbnail = thumbnail?.fields || nodeData
        include thumbnail
        div(class="col-span-5")
            a(class="inline-block font-sans text-lg mt-2 mr-4 underline decoration-zinc-300 hover:decoration-zinc-800" href=`/${canonical(nodeData.id, itemHeadline)}`)
                span(aria-label="name") #{itemHeadline}
            span(class="float-right pr-2 pt-1 select-none") #{icon(nodeType)}
            - item = nodeData
            include primary-properties

//- The headline should only be valid for this concrete item, but it is a global variable.
//- Therefore, deleting it here, so the headline is not accidentally used for a different node somewhere else.
- itemHeadline = null
