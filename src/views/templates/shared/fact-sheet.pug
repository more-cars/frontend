section(data-testid="fact-sheet" class="bg-zinc-100 p-5 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
    hgroup
        h2(class="text-2xl mb-2 border-b-2 border-lime-500") Fact Sheet
        p(class="mb-4") This database record has the More Cars ID #[b #{item.id}].

    table(class="w-full rounded-lg border-separate border-spacing-1.5 bg-zinc-200 mb-4")
        tbody
            - const nodeSpecificProperties = node.node_properties.filter(prop => !['id', 'created_at', 'updated_at'].includes(prop.name))
            each prop in nodeSpecificProperties
                - const propertyLabel = prop.label
                - const propertyValue = item[prop.name] ? item[prop.name] : ''
                tr(data-testid=`${prop.name}`)
                    td(class="w-1/3 p-2 font-bold text-right text-zinc-600") #{propertyLabel}
                    td(class="p-2 rounded-md border text-zinc-700 border-zinc-300 bg-zinc-50") #{propertyValue}

    table(class="w-full rounded-lg border-separate border-spacing-1.5 bg-zinc-200")
        tbody
            - const internalProperties = node.node_properties.filter(prop => ['id', 'created_at', 'updated_at'].includes(prop.name))
            each prop in internalProperties
                - const propertyLabel = prop.label
                - let propertyValue = item[prop.name] ? item[prop.name] : ''
                - if(['created_at', 'updated_at'].includes(prop.name)) propertyValue = formatDateTime(propertyValue)
                tr(data-testid=`${prop.name}`)
                    td(class="w-1/3 p-2 font-bold text-right text-zinc-600") #{propertyLabel}
                    td(class="p-2 rounded-md border text-zinc-700 border-zinc-300 bg-zinc-50") #{propertyValue}
