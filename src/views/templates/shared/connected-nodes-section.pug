if nodeItems.length > 0 && nodeItems[0] !== null
    section(data-testid=`${nodeType}-section` class="mb-8")
        hgroup
            h2(class="text-2xl mb-2 border-b-2 border-lime-500") #{sectionHeadline}
                if nodeItems.length > 1
                    span(class="float-right text-sm rounded-full px-2 py-1 bg-lime-500 border-4 border-white") #{nodeItems.length}
            p(class="mb-4")= sectionIntro

        ul
            each nodeItem in nodeItems
                - nodeUrlPath = nodeUrlBasePath + '/' + nodeItem.id
                - thumbnail = thumbnails ? thumbnails.get(nodeItem.id) : nodeItem
                - itemHeadline = itemHeadlineProperty ? nodeItem[itemHeadlineProperty] : nodeItem['name']
                include list-node-item
            - thumbnails = null
