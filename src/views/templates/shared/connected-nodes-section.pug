mixin connected-nodes-section(nodes, headline, introText, thumbnails, nodeProperties, sectionName)
    if nodes.length > 0 && nodes[0] !== null
        section(data-testid=`${sectionName || nodes[0].type.replaceAll('_', '-')}-section` class="mb-6 bg-zinc-100 p-5 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
            hgroup
                h2(class="text-2xl mb-2 border-b-2 border-lime-500") #{headline}
                    span(class="float-right text-sm rounded-full px-2.5 py-1 bg-white border-2 border-lime-500 outline-4 outline-zinc-100") #{nodes.length}
                p(class="mb-4")= introText

            ul(class="max-h-150 overflow-y-auto")
                each node in nodes
                    - thumbnail = thumbnails ? thumbnails.get(node.fields.id) : null
                    include list-node-item
                    +list-node-item(node, thumbnail)
