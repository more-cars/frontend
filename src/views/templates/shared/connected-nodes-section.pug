if nodeItems.length > 0 && nodeItems[0] !== null
    section(data-testid=`${sectionName || nodeType}-section` class="mb-6 bg-zinc-100 p-5 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
        hgroup
            h2(class="text-2xl mb-2 border-b-2 border-lime-500") #{sectionHeadline}
                if nodeItems.length > 1
                    span(class="float-right text-sm rounded-full px-2.5 py-1 bg-white border-2 border-lime-500 outline-4 outline-zinc-100") #{nodeItems.length}
            p(class="mb-4")= sectionIntro

        ul(class="max-h-150 overflow-y-auto")
            each node in nodeItems
                - nodeData = node.fields
                - thumbnail = thumbnails ? thumbnails.get(nodeData.id) : nodeData
                - itemHeadline = itemHeadlineProperty ? nodeData[itemHeadlineProperty] : nodeData['name']
                include list-node-item

- thumbnails = null
- sectionName = null
- itemHeadlineProperty = null