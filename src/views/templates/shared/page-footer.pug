footer(class="max-w-7xl mx-auto p-4 md:p-8 text-blue-50")
    ul(class="md:flex md:flew-row gap-6 md:gap-12")
        li(class="mb-6")
            h2(class="font-sans text-xl font-bold mb-2") About
            p More Cars is an open car database. The provided data can be used for free, for any purpose.
            nav(aria-label="Social Media Links")
                ul(class="mt-4")
                    li(class="inline-block")
                        a(class="inline-block border-2 border-transparent hover:border-white rounded-md p-1 mr-4" href="/" aria-label="More Cars start page")
                            img(class="h-12" src="/g/more-cars.svg" alt="")
                    li(class="inline-block")
                        a(class="inline-block border-2 border-transparent hover:border-white rounded-md p-1 mr-4" href="https://www.flickr.com/photos/more-cars/" aria-label="More Cars photos at Flickr")
                            img(class="h-12" src="/g/flickr.svg" alt="")
                    li(class="inline-block")
                        a(class="inline-block border-2 border-transparent hover:border-white rounded-md p-1 mr-4" href="https://www.youtube.com/@more-cars" aria-label="More Cars videos at YouTube")
                            img(class="h-12" src="/g/youtube.svg" alt="")
                    li(class="inline-block")
                        a(class="inline-block border-2 border-transparent hover:border-white rounded-md p-2 mr-4" href="https://www.instagram.com/more_cars_net/" aria-label="More Cars photos at Instagram")
                            img(class="h-10" src="/g/instagram.svg" alt="")

        li(class="mb-6")
            h2(class="font-sans text-xl font-bold mb-2") Top Pages
            nav(aria-label="Top Links")
                ul
                    li(class="relative before:content-['🛞'] before:absolute before:-ml-6 before:opacity-0 hover:before:opacity-100 before:transition")
                        a(href="/car-model-variants") Car Model Variants
                    li(class="relative before:content-['🛞'] before:absolute before:-ml-6 before:opacity-0 hover:before:opacity-100 before:transition")
                        a(href="/racing-events") Racing Events
                    li(class="relative before:content-['🛞'] before:absolute before:-ml-6 before:opacity-0 hover:before:opacity-100 before:transition")
                        a(href="/magazine-issues") Magazine Issues
        li(class="mb-6")
            h2(class="font-sans text-xl font-bold mb-2") Legal
            nav(aria-label="legal-links")
                ul
                    li(class="relative before:content-['🖋️️'] before:absolute before:-ml-6 before:opacity-0 hover:before:opacity-100 before:transition")
                        a(href="/contact") Contact / Impressum
                    li(class="relative before:content-['🖋️'] before:absolute before:-ml-6 before:opacity-0 hover:before:opacity-100 before:transition")
                        a(href="/privacy") Privacy Policy / Datenschutz
