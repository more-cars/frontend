extends ../../layouts/base/layout

block main
    h1(class="text-center mb-8 text-3xl font-bold") #{main_headline}

    if node_collection.length === 0
        include ../shared/nodes-not-found-warning
        +nodes-not-found-warning(node_type)
    else
        div(class="grid md:grid-cols-2 gap-6 items-start")
            section(data-testid=`${node_type}-section`)
                ul(class="mb-6 max-h-150 overflow-auto bg-zinc-100 p-5 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
                    each node in node_collection
                        - itemHeadline = node_titles.get(node.fields.id)
                        - thumbnail = thumbnails ? thumbnails.get(node.fields.id) : null
                        - nodeProperties = node_properties
                        include ../shared/list-node-item
                        +list-node-item(node, node_type, itemHeadline, thumbnail)
            include ../shared/search-tools
