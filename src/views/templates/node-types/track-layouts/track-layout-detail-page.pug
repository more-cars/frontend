extends ../../node-types/detail-page

block sub_headline
    - trackLayout = node.data
    | #{trackLayout.length} #{trackLayout.length_unit} | #{trackLayout.year_from} - #{trackLayout.year_to}

block relationships
    - trackLayout = node.data

    - raceTrack = relationships.race_track.item
    include connected-race-track

    - racingEvents = relationships.racing_events.items
    include connected-racing-events

    - racingGames = relationships.racing_games.items
    include connected-racing-games

    - images = relationships.images.items
    include ../../shared/connected-images
