extends ../../layouts/base/layout

block main
    - item = node.data.fields
    - mainImage = node.main_image

    div(class="grid grid-cols-2 gap-6 items-start")
        div(data-testid="main-area-primary")
            div(class="mb-6 bg-zinc-100 p-5 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
                hgroup(class="p-4 mb-4 border-y-3 border-lime-500 rounded-lg")
                    h1(class=`mb-1 text-3xl`)
                        span(class="float-right text-5xl select-none") #{icon(node.type)}
                        span #{node.title || item.name}
                    p(class="text-sm") #{node.sub_title}
                include ../shared/connected-main-image

            include ../shared/fact-sheet

        div(data-testid="main-area-secondary")
            block relationships

block footer
    p Footer area...
