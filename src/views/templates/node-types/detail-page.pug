extends ../../layouts/base/layout

block main
    - item = node.data.fields
    - mainImage = node.main_image
    - mainVideo = node.main_video

    div(class="grid md:grid-cols-8 gap-6 items-start")
        div(class=`${['image', 'video'].includes(node.data.type) ? 'col-span-5' : 'col-span-4'}` data-testid="main-area-primary")
            div(class="mb-6 bg-zinc-100 p-4 rounded-2xl outline-2 outline-zinc-100 border-4 border-white")
                hgroup(class="p-4 mb-4 border-y-3 border-lime-500 rounded-lg")
                    h1(class=`mb-1 text-3xl`)
                        span(class="float-right text-5xl select-none") #{icon(node.data.type)}
                        span #{node.title}
                    p(class="text-sm") #{node.sub_title}
                if mainVideo
                    include ../shared/connected-main-video
                else
                    include ../shared/connected-main-image

            include ../shared/fact-sheet

        div(class=`${['image', 'video'].includes(node.data.type) ? 'col-span-3' : 'col-span-4'}` data-testid="main-area-secondary")
            block relationships
