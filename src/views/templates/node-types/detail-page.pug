extends ../../layouts/base/layout

block main
    - item = node.data
    - mainImage = node.main_image

    div(class="grid grid-cols-2 gap-10 items-start")
        div(data-testid="main-area-primary")
            hgroup(class="py-4 mb-4 border-y-3 border-lime-500")
                h1(class=`mb-1 text-3xl`)
                    span(class="float-right mr-3 text-5xl select-none") #{icon(node.type)}
                    span #{main_headline || item.name}
                p(class="text-sm")
                    block sub_headline
            include ../shared/connected-main-image
            include ../shared/fact-sheet

        div(data-testid="main-area-secondary")
            block relationships

block footer
    p Footer area...
