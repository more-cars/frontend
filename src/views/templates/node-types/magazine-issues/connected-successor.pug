if successor
    section(data-testid="magazine-issue-section" class="mb-8")
        h2(class="text-2xl mb-2 border-b-2 border-lime-500") Successor
        p(class="mb-4") #[b #{magazineIssue.title}] is the predecessor of the following magazine issue:

        ul
            - nodeItem = successor
            - nodeType = 'magazine-issue'
            - nodeUrlPath = 'magazine-issues/' + nodeItem.id
            - thumbnail = relationships.successor.thumbnails.get(nodeItem.id)
            - nodeProperties = relationships.successor.node_properties
            - itemHeadline = nodeItem.title
            include ../../shared/list-node-item
