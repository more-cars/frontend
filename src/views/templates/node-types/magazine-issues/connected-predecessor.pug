if predecessor
    section(data-testid="magazine-issue-section" class="mb-8")
        h2(class="text-2xl mb-2 border-b-2 border-lime-500") Predecessor
        p(class="mb-4") #[b #{magazineIssue.title}] is the successor of the following magazine issue:

        ul
            - nodeItem = predecessor
            - nodeType = 'magazine-issue'
            - nodeUrlPath = 'magazine-issues/' + nodeItem.id
            - thumbnail = relationships.predecessor.thumbnails.get(nodeItem.id)
            - nodeProperties = relationships.predecessor.node_properties
            - itemHeadline = nodeItem.title
            include ../../shared/list-node-item
