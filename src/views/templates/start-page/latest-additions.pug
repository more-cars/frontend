section(class="mb-8 bg-zinc-100 rounded-2xl outline-2 outline-zinc-100 border-4 border-white" data-testid="latest-additions-section")
    h2(class="text-center text-xl m-4 mb-0") Latest Additions
    ul(class="flex overflow-x-auto p-4")
        each nodeItem in latest_additions
            - node = nodeItem.fields
            - thumbnail = thumbnails.get(node.id).fields
            li(class="flex-none p-2 pb-0 mr-4 bg-white border-2 border-white hover:border-zinc-200 rounded-xl")
                a(class="block font-sans text-center" href=`/car-model-variants/${node.id}`)
                    img(class="h-24 w-full object-cover rounded-lg" src=`${thumbnail['image_url_s']}`)
                    span(class="inline-block px-2 pt-2 pb-1") #{node.name}
