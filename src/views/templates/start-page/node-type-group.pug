mixin node-type-group(headline, items)
    section(class="mb-8 bg-zinc-100 rounded-2xl outline-2 outline-zinc-100 border-4 border-white" data-testid="node-type-group-section")
        h2(class="text-center text-xl m-4 mb-0") #{headline}
        ul(class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 p-4")
            each nodeType in items
                include node-type-group-item
