doctype html
html(lang="en")
    head
        title #{page_title} - More Cars
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        if search_data && (search_data.page > 1 || search_data.sort_by_property || search_data.sort_direction)
            meta(name="robots" content="noindex")
        block styles
            link(rel='stylesheet', href='/stylesheets/main.css')
            link(rel="icon", type="image/svg+xml", href="/g/favicon.svg")

    body(class="bg-gray-800")
        header(class="p-8 max-w-7xl m-auto")
            div(class="logo text-5xl text-center font-bold")
                a(href="/") ⚯ MORE ⚯ CARS ⚯

        main(class="p-6 max-w-7xl m-auto xl:rounded-2xl bg-white")
            block main

        include ../../templates/shared/page-footer
