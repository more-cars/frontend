{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "types": [
      "node",
      "cypress"
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*",
    "node_modules/cypress/types/cypress-global-vars.d.ts"
  ]
}
