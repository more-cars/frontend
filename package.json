{
  "author": "Dennis Gerike",
  "dependencies": {
    "@tailwindcss/cli": "4.3.0",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "change-case": "5.4.4",
    "compression": "1.8.1",
    "copyfiles": "2.4.1",
    "express": "5.2.1",
    "inflection": "3.0.2",
    "pug": "3.0.4",
    "tailwindcss": "4.3.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "undici": "8.5.0",
    "url-slug": "5.0.1"
  },
  "description": "Frontend for the open car database 'More Cars'",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "@cucumber/cucumber": "13.0.0",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@inquirer/prompts": "8.5.2",
    "@types/k6": "2.0.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "ajv": "8.20.0",
    "cypress": "15.17.0",
    "dotenv": "17.4.2",
    "hygen": "6.2.11",
    "inquirer": "14.0.2",
    "lighthouse": "13.4.0",
    "openapi-backend": "5.17.0",
    "sloc": "0.3.2",
    "supertest": "7.2.2",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=26"
  },
  "license": "MIT",
  "name": "@more-cars/frontend",
  "repository": "https://github.com/more-cars/frontend",
  "scripts": {
    "build": "npm run build:code && npm run build:assets && npm run build:css",
    "build:code": "tsc -p tsconfig.app.json",
    "build:css": "npx @tailwindcss/cli -i src/views/stylesheets/main.css -o ./public/stylesheets/main.css --minify",
    "build:assets": "copyfiles -u 1 'src/**/*.json' dist",
    "start": "NODE_ENV=production node dist/server.js",
    "local:app:start": "./deployment/local-app-start.sh",
    "local:mockserver:start": "./tests/behavior/local-mock-server-start.sh",
    "local:hostnames:add": "./deployment/add-local-hostnames.sh",
    "generate-code": "TS_NODE_PROJECT=tsconfig.app.json node --env-file=.env -r ts-node/register code-generator/generate-code-for-specific-feature.ts",
    "app:deploy": "./deployment/deploy-app.sh",
    "app:undeploy": "./deployment/undeploy-app.sh",
    "minikube:install": "deployment/minikube-install.sh",
    "minikube:start": "deployment/minikube-cluster-start.sh",
    "minikube:stop": "deployment/minikube-cluster-stop.sh",
    "minikube:delete": "deployment/minikube-cluster-delete.sh",
    "lint:code": "npx eslint src",
    "lint:tests": "npx eslint tests",
    "tests:developer": "npx vitest run -c tests/developer/vite.config.ts",
    "tests:developer:coverage": "npx vitest run -c tests/developer/vite.config.ts --coverage",
    "tests:behavior:gui": "npx cypress open",
    "tests:behavior:cli": "tests/behavior/run-behavior-tests.sh",
    "tests:performance": "K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_OPEN=true K6_WEB_DASHBOARD_EXPORT=test-reports/performance/report.html FRONTEND_URL=http://localhost:4000 k6 run tests/performance/node-types/car-models/get-car-model.ts",
    "tests:lighthouse": "tests/lighthouse/run-lighthouse-tests.sh",
    "stats:lines-of-code:src": "sloc src/",
    "stats:lines-of-code:test": "sloc tests/"
  },
  "version": "2.1.0"
}
